<div class="svg-container"><svg width="550" height="100" viewBox="0 0 550 100"><line x1="20" y1="50" x2="530" y2="50" stroke="#333" stroke-width="1"/><path d="M30 50 L55 42 L80 55 L105 48 L130 55 L155 50 L180 42 L205 55 L230 48 L255 55 L280 50 L305 42 L330 55 L355 48 L380 55 L405 50 L430 42 L455 55 L480 48 L505 55 L530 50" fill="none" stroke="#b60000" stroke-width="1.5"/><text x="280" y="25" font-size="11" fill="#b60000" text-anchor="middle">Шум n(t) — белый гауссовский (AWGN)</text></svg></div>

